# ========================================
# 按运营主体拆表工具 - 配置模板
# ========================================
# 首次使用时，复制此文件为 config.yaml 并填写以下信息
# 配置文件位置：~/.claude/skills/lx-zhutichaibiao/assets/config.yaml
# ========================================

# ========================================
# 用户配置（首次运行时自动询问生成）
# ========================================

# 项目根目录（绝对路径）
# 示例：/Users/xxx/projects/my-project
项目根目录: ""

# 码表文件路径（绝对路径或相对于项目根目录）
# 码表包含：城市、品牌、运营主体、对接人 的映射关系
# 示例：./data/码表.xlsx 或 /Users/xxx/projects/my-project/data/码表.xlsx
码表路径: ""

# 对接人（用于筛选码表中的运营主体）
# - 单个名字（如 LWL）
# - 多个名字（逗号分隔，如 LWL,张三）
# - "全部" 表示所有对接人
对接人: ""

# 工作目录（绝对路径或相对于项目根目录）
# 目录下需包含：待拆表/、已拆表/、原表存档/ 三个子目录
# 示例：./p-主体拆表
工作目录: ""

# ========================================
# 拆分规则配置
# ========================================

默认:
  # 城市字段名列表（匹配任意一个）
  城市字段:
    - 城市
    - 城市名称
    - 注册城市
    - 所属城市
    - city_name
  # 品牌字段名列表（匹配任意一个）
  品牌字段:
    - 品牌
    - 品牌名称
    - 商家
    - 商家名称
    - 合作品牌
    - 合作商家
  # 处理的sheet列表（留空则处理所有sheet）
  处理sheet: []

# 针对特定文件的配置（按文件名关键词匹配，优先级高于默认配置）
特定配置:
  # ----------------------------------------
  # 示例：LX四城权益分截止 系列
  # 汇总1字段：品牌、城市
  # 司机明细字段：品牌名称、city_name
  # ----------------------------------------
  - 匹配: "LX四城权益分截止"
    城市字段:
      - city_name
      - 城市
    品牌字段:
      - 品牌名称
      - 品牌
    处理sheet:
      - 汇总1
      - 司机明细

  # ----------------------------------------
  # 更多示例（根据需要添加）
  # ----------------------------------------
  # - 匹配: "潜力宏鹄新司机明细"
  #   城市字段:
  #     - 注册城市
  #   品牌字段:
  #     - 品牌名称
  #   处理sheet: []              # 留空处理所有sheet